{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Compliance Patch",
  "description": "Schema representing a reconciled compliance patch generated by comparing two versions of SEBI regulatory circulars.",
  "type": "object",
  "required": [
    "patch_id",
    "patch_type",
    "old_circular",
    "new_circular",
    "affected_obligation",
    "impact_level",
    "affected_departments",
    "reasoning",
    "source_clause",
    "target_clause",
    "generated_at"
  ],
  "properties": {
    "patch_id": {
      "type": "string",
      "description": "Unique identifier for the generated patch.",
      "example": "PATCH-2026-001"
    },
    "patch_type": {
      "type": "string",
      "description": "Type of regulatory change detected.",
      "enum": [
        "NEW",
        "MODIFIED",
        "SUPERSEDED",
        "REMOVED"
      ]
    },
    "old_circular": {
      "type": "string",
      "description": "Previous SEBI circular version."
    },
    "new_circular": {
      "type": "string",
      "description": "Updated SEBI circular version."
    },
    "affected_obligation": {
      "type": "string",
      "description": "Identifier of the impacted obligation.",
      "example": "OBL-2026-001"
    },
    "impact_level": {
      "type": "string",
      "enum": [
        "High",
        "Medium",
        "Low"
      ]
    },
    "affected_departments": {
      "type": "array",
      "description": "Departments impacted by this regulatory change.",
      "items": {
        "type": "string"
      }
    },
    "reasoning": {
      "type": "string",
      "description": "AI-generated explanation describing why the patch was created."
    },
    "source_clause": {
      "type": "string",
      "description": "Clause reference from the previous circular."
    },
    "target_clause": {
      "type": "string",
      "description": "Clause reference from the updated circular."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "review_status": {
      "type": "string",
      "description": "Human validation status.",
      "enum": [
        "Pending Review",
        "Approved",
        "Rejected"
      ]
    }
  }
}